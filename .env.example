# Copy to .env and fill in before running `docker compose up`. .env is gitignored; never commit
# real values (see CLAUDE.md's Secrets section).

# Tailscale auth key for the sidecar container (Settings -> Keys on the Tailscale admin console).
# Use a reusable, non-ephemeral key so the container survives a restart with the same identity.
TS_AUTHKEY=

# Same secrets curation_server.py's host-run scripts already read from repo-root .envrc.
RUNPOD_API_KEY=
CIVITAI_TOKEN=
CIVITAI_MODEL_ID=

# Plain OpenAI API key (not the ChatGPT OAuth login `opencode auth login` uses on the host).
# opencode reads OPENAI_API_KEY directly, so the container never needs the host's
# ~/.local/share/opencode/auth.json mounted in.
OPENAI_API_KEY=

# Which dataset directory to serve, relative to the ./notes bind mount inside the container.
# Defaults to /app/notes/uncanny_sweep if unset.
CLAWMARKS_SWEEP_DIR=/app/notes/uncanny_sweep
